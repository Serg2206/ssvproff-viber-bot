# Telegram Bot Token (обязательно)
# Получить у @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Provider API Keys (минимум один нужен для /ask)
ABACUSAI_API_KEY=your_abacus_ai_key_here
KIMI_API_KEY=your_kimi_api_key_here

# Admin Telegram Chat ID для уведомлений об ошибках (опционально)
ADMIN_CHAT_ID=your_telegram_chat_id_here

# Webhook URL (опционально, для production на сервере)
WEBHOOK_URL=

# Server Port (для webhook mode, опционально)
PORT=8443

# AI Provider: 'abacus', 'kimi', или 'auto' (попробует оба)
AI_PROVIDER=auto
